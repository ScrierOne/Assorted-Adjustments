	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),BLUE_FIRESHIELD)
		CheckStatGT(Myself,99,RESISTCOLD)
	!IsWeaponRanged(Myself)
THEN
	RESPONSE #100
		Attack(NearestEnemyOf(Myself))
END

