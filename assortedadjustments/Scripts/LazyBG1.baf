IF
	ActionListEmpty()
	GlobalGT("Healing","LOCALS",0)
	CombatCounter(0)
	!Detect(NearestEnemyOf(Myself))
	!CheckStatGT(Myself,0,SPELLFAILUREPRIEST)
	HaveSpell(PALADIN_LAY_ON_HANDS)  // SPCL211.SPL (Lay On Hands)
	!CheckStatGT(Myself([PC]),0,WIZARD_SPELL_TURNING)
	!CheckStatGT(Myself([PC]),0,WIZARD_SPELL_TRAP)
	!CheckStatGT(Myself([PC]),0,WIZARD_SPELL_DEFLECTION)
	!CheckStatGT(Myself([PC]),0,CLERIC_SHIELD_OF_THE_ARCHONS)
	HPPercentLT(Myself([PC]),90)
THEN
	RESPONSE #100
		Spell(Myself([PC]),PALADIN_LAY_ON_HANDS)  // SPCL211.SPL (Lay On Hands)
END

