IF
	HotKey(S)
THEN
	RESPONSE #100
		EquipMostDamagingMelee()
END

IF
	HotKey(D)
THEN
	RESPONSE #100
		EquipRanged()
END

IF
	Global("Thieving","LOCALS",0)
	!Class(Myself,BARD_ALL)
	HotKey(G)
THEN
	RESPONSE #100
		SetGlobal("Thieving","LOCALS",1)
		DisplayStringHead(Myself,25482)  // Attempting to hide in shadows
END

IF
	Global("Thieving","LOCALS",1)
	!Class(Myself,BARD_ALL)
	HotKey(G)
THEN
	RESPONSE #100
		SetGlobal("Thieving","LOCALS",0)
		DisplayStringHead(Myself,25483)  // Searching for traps
END

IF
	Global("BardSong","LOCALS",0)
	Class(Myself,BARD_ALL)
	HotKey(G)
THEN
	RESPONSE #100
		SetGlobal("BardSong","LOCALS",1)
		DisplayStringHead(Myself,25486)  // Singing constantly if idle
END

IF
	Global("BardSong","LOCALS",1)
	Class(Myself,BARD_ALL)
	HotKey(G)
THEN
	RESPONSE #100
		SetGlobal("BardSong","LOCALS",0)
		DisplayStringHead(Myself,25487)  // Singing only during combat
END

IF
	Global("Attacking","LOCALS",0)
	HotKey(A)
THEN
	RESPONSE #100
		SetGlobal("Attacking","LOCALS",1)
		DisplayStringHead(Myself,25488)  // Attacking enemies
END

IF
	Global("Attacking","LOCALS",1)
	HotKey(A)
THEN
	RESPONSE #100
		SetGlobal("Attacking","LOCALS",0)
		DisplayStringHead(Myself,25489)  // Not attacking enemies
END

IF
	Global("BardSong","LOCALS",1)
	OR(2)
		Global("BardInCombat","LOCALS",0)
		Global("Attacking","LOCALS",0)
	ActionListEmpty()
	Class(Myself,BARD_ALL)
	!ModalState(BATTLESONG)
	!StateCheck(Myself,STATE_INVISIBLE)
THEN
	RESPONSE #100
		BattleSong()
END

IF
	Global("BardSong","LOCALS",0)
	Global("Attacking","LOCALS",0)
	ActionListEmpty()
	Class(Myself,BARD_ALL)
	!ModalState(BATTLESONG)
	!StateCheck(Myself,STATE_INVISIBLE)
	OR(2)
		See([EVILCUTOFF])
		CombatCounterGT(0)
THEN
	RESPONSE #100
		BattleSong()
END

// Bards auto-attack when Battlesong is on, but not when manually ordered to sing in combat:

IF
	Global("BardSong","LOCALS",1)
	Global("Attacking","LOCALS",1)
	GlobalLT("BardInCombat","LOCALS",1)
	ActionListEmpty()
	See([EVILCUTOFF])
	!Class(NearestEnemyOf(Myself),INNOCENT)
	!StateCheck(Myself,STATE_INVISIBLE)
	CheckStatLT(Myself,1,SANCTUARY)
	ModalState(BATTLESONG)
	WeaponEffectiveVs(NearestEnemyOf(Myself),MAINHAND)
	WeaponCanDamage(NearestEnemyOf(Myself),MAINHAND)
	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),RED_FIRESHIELD)
		CheckStatGT(Myself,99,RESISTFIRE)
	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),BLUE_FIRESHIELD)
		CheckStatGT(Myself,99,RESISTCOLD)
	!IsWeaponRanged(Myself)
THEN
	RESPONSE #100
		ClearActions(Myself)
		SetGlobal("BardInCombat","LOCALS",1)
END

IF
	Global("BardSong","LOCALS",1)
	Global("Attacking","LOCALS",1)
	GlobalLT("BardInCombat","LOCALS",1)
	ActionListEmpty()
	See([EVILCUTOFF])
	!Class(NearestEnemyOf(Myself),INNOCENT)
	!StateCheck(Myself,STATE_INVISIBLE)
	CheckStatLT(Myself,1,SANCTUARY)
	ModalState(BATTLESONG)
	WeaponEffectiveVs(NearestEnemyOf(Myself),MAINHAND)
	WeaponCanDamage(NearestEnemyOf(Myself),MAINHAND)
	IsWeaponRanged(Myself)
THEN
	RESPONSE #100
		SetGlobal("BardInCombat","LOCALS",1)
		ClearActions(Myself)
END

IF
	Global("BardInCombat","LOCALS",1)
	ModalState(BATTLESONG)
THEN
	RESPONSE #100
		SetGlobal("BardInCombat","LOCALS",2)
		ClearActions(Myself)
		BattleSong()
END

IF
	Global("BardInCombat","LOCALS",2)
	ActionListEmpty()
	!ModalState(BATTLESONG)
THEN
	RESPONSE #100
		SetGlobal("BardInCombat","LOCALS",1)
END

IF
	GlobalGT("BardInCombat","LOCALS",0)
	!See([EVILCUTOFF])
THEN
	RESPONSE #100
		SetGlobal("BardInCombat","LOCALS",0)
END

// Thieves auto-attack when auto-detecting is on, but not when manually ordered to in combat:

IF
	Global("Thieving","LOCALS",0)
	Global("Attacking","LOCALS",1)
	GlobalLT("ThiefInCombat","LOCALS",1)
	ActionListEmpty()
	See([EVILCUTOFF])
	!StateCheck(Myself,STATE_INVISIBLE)
	CheckStatLT(Myself,1,SANCTUARY)
	ModalState(DETECTTRAPS)
	WeaponEffectiveVs(NearestEnemyOf(Myself),MAINHAND)
	WeaponCanDamage(NearestEnemyOf(Myself),MAINHAND)
	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),RED_FIRESHIELD)
		CheckStatGT(Myself,99,RESISTFIRE)
	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),BLUE_FIRESHIELD)
		CheckStatGT(Myself,99,RESISTCOLD)
	!IsWeaponRanged(Myself)
THEN
	RESPONSE #100
		ClearActions(Myself)
		SetGlobal("ThiefInCombat","LOCALS",1)
END

IF
	Global("Thieving","LOCALS",0)
	Global("Attacking","LOCALS",1)
	Global("ThiefInCombat","LOCALS",0)
	ActionListEmpty()
	See([EVILCUTOFF])
	!StateCheck(Myself,STATE_INVISIBLE)
	CheckStatLT(Myself,1,SANCTUARY)
	ModalState(DETECTTRAPS)
	WeaponEffectiveVs(NearestEnemyOf(Myself),MAINHAND)
	WeaponCanDamage(NearestEnemyOf(Myself),MAINHAND)
	IsWeaponRanged(Myself)
THEN
	RESPONSE #100
		SetGlobal("ThiefInCombat","LOCALS",1)
		ClearActions(Myself)
END

IF
	Global("ThiefInCombat","LOCALS",1)
	ModalState(DETECTTRAPS)
THEN
	RESPONSE #100
		SetGlobal("ThiefInCombat","LOCALS",2)
		ClearActions(Myself)
		FindTraps()
END

IF
	Global("ThiefInCombat","LOCALS",2)
	ActionListEmpty()
	!ModalState(DETECTTRAPS)
THEN
	RESPONSE #100
		SetGlobal("ThiefInCombat","LOCALS",1)
END

IF
	GlobalGT("ThiefInCombat","LOCALS",0)
	!See([EVILCUTOFF])
THEN
	RESPONSE #100
		SetGlobal("ThiefInCombat","LOCALS",0)
END

IF
	Global("Thieving","LOCALS",0)
	ActionListEmpty()
	OR(4)
		!See([EVILCUTOFF])
		Global("Attacking","LOCALS",0)
		StateCheck(Myself,STATE_INVISIBLE)
		CheckStat(Myself,1,SANCTUARY)
	OR(2)
		Class(Myself,THIEF_ALL)
		Class(Myself,MONK)
	!ModalState(TURNUNDEAD)
	!ModalState(DETECTTRAPS)
	!ModalState(STEALTH)
THEN
	RESPONSE #100
		FindTraps()
END

IF
	Global("Thieving","LOCALS",1)
	!GlobalTimerNotExpired("Hiding","LOCALS")
	ActionListEmpty()
	!See([EVILCUTOFF])
	OR(3)
		Class(Myself,THIEF_ALL)
		Class(Myself,RANGER_ALL)
		Class(Myself,MONK)
	!ModalState(TURNUNDEAD)
	!ModalState(STEALTH)
	!ButtonDisabled(BUTTON_THIEVING)
THEN
	RESPONSE #100
		SetGlobalTimer("Hiding","LOCALS",ONE_ROUND)
		Hide()
END

IF
	Global("Attacking","LOCALS",1)
	ActionListEmpty()
	!StateCheck(Myself,STATE_INVISIBLE)
	CheckStatLT(Myself,1,SANCTUARY)
	See([EVILCUTOFF])
	!Class(NearestEnemyOf(Myself),INNOCENT)
	!InParty([EVILCUTOFF])
	!ModalState(TURNUNDEAD)
	!ModalState(DETECTTRAPS)
	!ModalState(BATTLESONG)
	WeaponEffectiveVs(NearestEnemyOf(Myself),MAINHAND)
	WeaponCanDamage(NearestEnemyOf(Myself),MAINHAND)
	OR(2)
		!CheckSpellState(NearestEnemyOf(Myself),RED_FIRESHIELD)
