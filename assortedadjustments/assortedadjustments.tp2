REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate:EE"

COPY_EXISTING 
	"SPCL814.spl" "override" // Monk Haste Immunity
		LPF DELETE_EFFECT INT_VAR match_opcode = 206 match_parameter2 = 16 END // Protection from spell: Haste
		LPF DELETE_EFFECT INT_VAR match_opcode = 101 match_parameter2 = 16 END // Immunity to Effect: Haste
		LPF DELETE_EFFECT INT_VAR match_opcode = 101 match_parameter2 = 126 END // Immunity to Effect: Movement rate bonus
		LPF DELETE_EFFECT INT_VAR match_opcode = 337 match_parameter2 = 16 END // Remove effect by opcode: Haste
		LPF DELETE_EFFECT INT_VAR match_opcode = 337 match_parameter2 = 126 END // Remove effect by opcode: movement rate bonus
		LPF DELETE_EFFECT INT_VAR match_opcode = 328 match_parameter2 = IDS_OF_SYMBOL (splstate HASTE_IMMUNITY) END // Spell State: Haste Immunity
		LPF DELETE_EFFECT INT_VAR match_opcode = 240 match_parameter2 = 38 END 	///remove portrait icon Haste 
		LPF DELETE_EFFECT INT_VAR match_opcode = 240 match_parameter2 = 195 END 	///remove portrait icon increased movement rate 
		LPF DELETE_EFFECT INT_VAR match_opcode = 169 match_parameter2 = 38 END 	///prevent  portrait icon Haste 
		LPF DELETE_EFFECT INT_VAR match_opcode = 169 match_parameter2 = 195 END 	///prevent  portrait icon increased movement rate 
		LPF DELETE_EFFECT INT_VAR match_opcode = 267 match_parameter2 = 16 END  //disable  display string hasted
IF_EXISTS BUT_ONLY

