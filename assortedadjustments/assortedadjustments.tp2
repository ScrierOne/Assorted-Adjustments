	"gorbat1.cre" "override"
	"dempit.cre" "override"
	"dempit01.cre"  "override"
	"dempitsu.cre"  "override"
	"dw#bazpf.cre" "override"
	"dw#pitsu.cre" "override"
	"telpit1.cre"  "override"
	"telpit2.cre"  "override"
			WRITE_SHORT 0x28 0xe091 //Animation (pit_fiend_nwn)
			WRITE_BYTE 0x2d 47 //Minor color (pure dark red)
			WRITE_BYTE 0x2e 46 //Major color (red)
			WRITE_BYTE 0x2f 46 //Skin color
	        LAUNCH_PATCH_FUNCTION DELETE_CRE_EFFECT
        INT_VAR opcode_to_delete = 51 //Strong-dark by RGB
      END
    BUT_ONLY IF_EXISTS

