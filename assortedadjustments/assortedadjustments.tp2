/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Prevent Mislead clones from being able to attack when speed weapons are equipped" DESIGNATED 110
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate:EE"

COPY_EXISTING
                  "mislead.spl"			"override"				// vanilla mislead
                  "g_misled.spl" 		"override"				// tnt Mislead
LPF DELETE_EFFECT INT_VAR match_opcode = 1 END
LPF DELETE_EFFECT INT_VAR match_opcode = 101 match_parameter2 = 1 END

LPF ADD_SPELL_EFFECT INT_VAR insert_point= 0 opcode = 1 timing = 1 target= 1 parameter1 = 0 parameter2 = 1 END
LPF ADD_SPELL_EFFECT INT_VAR insert_point= 1 opcode = 1 timing = 9 target= 1 parameter1 = "-4" parameter2 = 0 END
LPF ADD_SPELL_EFFECT INT_VAR insert_point= 2 opcode = 101 timing = 9 target= 1 parameter2 = 1 END
IF_EXISTS BUT_ONLY

