	WRITE_SHORT 0x28 0x6111 // Animation ID (fighter_female_elf)
	REPLACE_CRE_ITEM "wings01" #0 #0 #0 "UNDROPPABLE" "HELMET"
BUT_ONLY IF_EXISTS

////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Give Displacer Beasts their Neverwinter Nights sprite animation" DESIGNATED 407
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee eet" "Game must be Baldur's Gate:EE"

	COPY 
	"%MOD_FOLDER%/IA/ccp_displacer_beast" "override"
	APPEND "animate.ids" "0x7002 DISPLACER_BEAST_NWN" UNLESS "^0x7002"  //write animate.ids

COPY_EXISTING
	"bddispbe.cre" "override" 
	"bddispbp.cre" "override" 
			WRITE_SHORT 0x28 0x7002 //Animation (displacer_beast_nwn)
	BUT_ONLY IF_EXISTS

////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Give Viconia her Sharran character colors from Siege of Dragonspear in BG1/BG2" DESIGNATED 408
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate"

COPY_EXISTING
	"viconi.cre" "override"
	"viconi4.cre" "override"
	"viconi6.cre" "override"
	"viconi7.cre" "override"
	"viconi8.cre" "override"
	"viconi9.cre" "override"
	"viconi11.cre" "override"
	"viconi13.cre" "override"
	"viconi16.cre" "override"
		WRITE_BYTE 0x02c 28 // Metal Color: Bluish Silver
		WRITE_BYTE 0x02d 117 // Major Color: Deep Indigo
		WRITE_BYTE 0x02e 190 // Minor Color: Dark Orchid
		WRITE_BYTE 0x02f 184 // Skin Color: Cadet Blue
		WRITE_BYTE 0x030 66 // Leather Color: Faded Black
		WRITE_BYTE 0x031 83 // Leather Color :Dark Bluish Grey
		WRITE_BYTE 0x032 105 // Hair Color: Off White
IF_EXISTS 
BUT_ONLY

////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Give Voghiln a more warrior-like appearance by giving him the Fighter animation and basic chain mail as his starting armor" DESIGNATED 409
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_INCLUDES "SOD" "Game must be Baldur's Gate: Siege of Dragonspear"

COPY_EXISTING
	"voghil7.cre" "override"
		WRITE_LONG 0x028 0x6100 // Animation: Fighter
		ADD_CRE_ITEM "chan01" #0 #0 #0 "None" "armor"
IF_EXISTS 
BUT_ONLY

////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Give Belhifet a Custom Portrait" DESIGNATED 410
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee eet iwdee" "Game must be BG1:EE/IWD:EE"

COPY_EXISTING
	"bdbelhif.cre" "override"
WRITE_EVALUATED_ASCII 0x34 ~BDBELHIF~ #8
IF_EXISTS 
BUT_ONLY
COPY
	"%MOD_FOLDER%/BMP/bdbelhif.bmp" "override"

COPY_EXISTING
	"bdvoice.cre" "override"
WRITE_EVALUATED_ASCII 0x34 ~BDVOICE~ #7
IF_EXISTS 
BUT_ONLY
COPY
	"%MOD_FOLDER%/BMP/bdvoice.bmp" "override"
	
////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Install Lazy Companion AI" DESIGNATED 500
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee iwdee" "Game must be BG1:EE/BG2:EE/IWD:EE"

  ACTION_IF (GAME_IS "bgee") BEGIN
	COPY
	"%MOD_FOLDER%/Scripts/LazyBG1.baf" "scripts/default.bs"
	COMPILE_BAF_TO_BCS
  END
  
  ACTION_IF (GAME_IS "bg2ee") BEGIN
	COPY
	"%MOD_FOLDER%/Scripts/LazyBG2.baf" "scripts/default.bs"
	COMPILE_BAF_TO_BCS
  END
  
  ACTION_IF (GAME_IS "iwdee") BEGIN
	COPY
	"%MOD_FOLDER%/Scripts/LazyIWD.baf" "scripts/default.bs"
	COMPILE_BAF_TO_BCS
  END
