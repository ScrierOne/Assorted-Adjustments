BACKUP "weidu_external/backup/assortedadjustments"
AUTHOR "Myname (my email address)"
AUTO_EVAL_STRINGS

LANGUAGE 
"English"  ~assortedadjustments/english~ ~assortedadjustments/english/english.tra~

/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Berserker Rage Disables Spellcasting" DESIGNATED 90
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet IWDEE" "Game must be EE"

COPY_EXISTING
	"spcl321.spl" "override" 		// Berserker Enrage
	"ragara1.spl" "override" 		// DoF special ability versions
	"ragruu4.spl" "override" 		// 
	"rahoar1.spl" "override" 		// 
	"ratemp1.spl" "override" 		//  
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=60 parameter2=0 END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=60 parameter2=1 END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=60 parameter2=3 END
BUT_ONLY IF_EXISTS 

/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Minsc Remains Controllable While Using His Rage" DESIGNATED 91
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate EE"

COPY_EXISTING
	"spin117.spl" "override" //Minsc Berserk
	SAY NAME1 @1																															// "Berserker Rage"
	SAY UNIDENTIFIED_DESC @2
	WRITE_EVALUATED_ASCII 0x3A ~ENRAGEB~ (8)										// Ability icons from berserk to enrage	
	WRITE_EVALUATED_ASCII 0x76 ~ENRAGEB~ (8)
	LPF ALTER_EFFECT INT_VAR silent = 1 match_opcode = 142 parameter2 = 141 END 	// Portrait icon from berserk to enrage
	LPF DELETE_EFFECT INT_VAR match_opcode = 3 END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=73 target=1 duration=120 parameter1=2 parameter2=1  END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=278 target=1 duration=120 parameter1=2 parameter2=0  END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=120 parameter2=0  END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=120 parameter2=1  END
	LPF ADD_SPELL_EFFECT INT_VAR insert_point=0 opcode=145 target=1 duration=120 parameter2=3  END
BUT_ONLY IF_EXISTS 

/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Roleplay-Friendly Berserk Script For Minsc" DESIGNATED 92
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate "
REQUIRE_COMPONENT "assortedadjustments.tp2" 91 "This component requires 'Minsc Remains Controllable While Using His Rage' to be installed"

EXTEND_BOTTOM "Minsc.bcs" "%MOD_FOLDER%/Scripts/party_friendly_berserk.baf"

ACTION_IF (GAME_INCLUDES "SoD") BEGIN
EXTEND_BOTTOM "BDMinsc.bcs" "%MOD_FOLDER%/Scripts/party_friendly_berserk.baf"
END

ACTION_IF (GAME_IS "bg2ee") BEGIN
EXTEND_BOTTOM "Mins25.bcs" "%MOD_FOLDER%/Scripts/party_friendly_berserk.baf"
END

/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Make sleep end upon taking damage" DESIGNATED 100
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "bgee bg2ee eet" "Game must be Baldur's Gate:EE"

COPY_EXISTING 
	"sppr102.spl" "override" // Command
	"sppr512.spl" "override" // Greater Command
	"spwi220.spl" "override" // Power Word: Sleep
	"spwi116.spl" "override" // Wizard Sleep
	"wand08.itm" "override" // Wand of Sleep
	"dwdart01.itm" "override"
	"dwbolt01.itm" "override" // Drow dart / bolt
	"dagg13.itm" "override" // Pixie Prick
	
	"RAWI220.spl" "override" // DOF Cleric PW: Sleep
	"RAWI116.spl" "override" // DOF Cleric Sleep
	"RAELDA2.SPL" "override"
	"RASHARE4.spl" "override" // DOF Sleep Gaze
	"RASHAR3.spl" "override"// DOF Nightmare
	
	"SPWI434.SPL" "override" // Made in Heaven Spellback Slumber
	
  LPF ALTER_EFFECT INT_VAR silent = 1 match_opcode = 39 parameter2 = 0 END
IF_EXISTS BUT_ONLY

	COPY "%MOD_FOLDER%/EFF/SLEEPY.EFF" "override"

