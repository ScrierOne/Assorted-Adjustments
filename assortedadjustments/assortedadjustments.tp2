/////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN "Fixes For Deities of Faerûn" DESIGNATED 107
/////////////////////////////////////////////////////////////////////////////////////////////////////
REQUIRE_PREDICATE GAME_IS "iwdee bgee bg2ee eet" "Game must be EE"
REQUIRE_COMPONENT "DeitiesOfFaerun.tp2" 0 "This component requires Deities of Faerûn to be installed"

// Tyr Cleric's Detect Invisibility at will:

COPY_EXISTING "RATYR4.spl" "override"
  LPF ADD_SPELL_EFFECT INT_VAR opcode = 171 target = 1 timing = 1 STR_VAR resource = "%SOURCE_RES%" END
  LPF CLONE_EFFECT INT_VAR match_opcode = 171 opcode = 172 END 
  IF_EXISTS BUT_ONLY 
  
 // Makes Holy Word not target party:
  
 COPY_EXISTING 
	"RATYR3.spl" "override" //  Holy Word, Tyr
	"RATORM5.spl" "override" // Holy Word, Torm

LPF ALTER_EFFECT INT_VAR match_opcode= 324 STR_VAR resource="%SOURCE_RES%" END
IF_EXISTS BUT_ONLY

// Makes Strength of One not override strength higher than 18/76:

  COPY_EXISTING 
	"RAARVO5.spl" "override" //  Strength of One, Arvoreen
	"RATYR2.spl" "override" //  Strength of One, Tyr
	"RACLAN3.spl" "override" //  Strength of One, Clangeddin

LPF ALTER_EFFECT INT_VAR match_opcode= 318 STR_VAR resource="%SOURCE_RES%" END  
IF_EXISTS BUT_ONLY

